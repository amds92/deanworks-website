<!-- ══ CARROS EM DESTAQUE ══ -->
<section class="carros" id="carros">
  <div class="wrap">
    <div class="carros-header reveal">
      <div>
        <div class="section-tag">Disponíveis agora</div>
        <h2 class="section-title">Viaturas <em>em destaque.</em></h2>
      </div>
      <div style="display:flex;gap:10px;flex-wrap:wrap;justify-content:flex-end;">
        <%= link_to "Ver todas →", vehicles_path, class: "btn btn-outline" %>
        <a href="#contacto" class="btn btn-outline" data-turbo="false">Pedir proposta →</a>
      </div>
    </div>
    <div class="carros-grid reveal" id="carros-grid">
      <% vehicles_to_show = (@featured_vehicles.presence || @vehicles).first(3) %>
      <% vehicles_to_show.each do |v| %>
        <% msg = "Olá, tenho interesse no #{[v.marca, v.modelo, v.ano].compact.join(' ')}." %>
        <% wa_link = "https://wa.me/351960100223?text=#{ERB::Util.url_encode(msg)}" %>
        <% cta_text = v.estado_reserved? ? "Reservado — Contactar" : "Pedir proposta" %>
        <div class="carro-card">
          <div class="carro-img">
            <% if v.photo.attached? %>
              <%= image_tag v.photo, style: "position:absolute;inset:0;width:100%;height:100%;object-fit:cover;", alt: "#{v.marca} #{v.modelo}", onerror: "this.style.display='none'" %>
            <% else %>
              <div class="carro-img-bg"></div><span>🚗</span>
            <% end %>
          </div>
          <div class="carro-body">
            <% if v.estado_reserved? %>
              <span class="carro-badge carro-badge-reservado">Reservado</span><br>
            <% end %>
            <div class="carro-make"><%= v.marca %><%= v.importada ? " · Importação" : "" %></div>
            <div class="carro-name"><%= v.modelo %><%= v.ano.present? ? " #{v.ano}" : "" %></div>
            <% if v.preco.present? %>
              <div style="font-size:13px;font-weight:600;color:var(--accent);margin-bottom:10px;">€<%= number_with_delimiter(v.preco, delimiter: ".") %><% if v.km.present? %> · <%= number_with_delimiter(v.km, delimiter: ".") %> km<% end %></div>
            <% end %>
            <div class="carro-desc"><%= v.descricao %></div>
            <a href="<%= wa_link %>" target="_blank" class="carro-cta"><%= cta_text %> <span>→</span></a>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>

